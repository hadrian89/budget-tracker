# ──────────────────────────────────────────────────────────────
# Walleto Web App — Environment Variables
# Copy this file to .env.development (for local dev) or set in
# your hosting provider's environment settings for production.
# ──────────────────────────────────────────────────────────────

# Backend API base URL
# For local dev: http://localhost:5001
# For testing on a device on your LAN: http://192.168.x.x:5001
# For production: https://your-backend.onrender.com
REACT_APP_API_URL=http://localhost:5001

# Google OAuth Client ID (optional — required only if using Google login)
# Create at https://console.cloud.google.com → APIs & Services → Credentials
REACT_APP_GOOGLE_CLIENT_ID=

# Facebook App ID (optional — required only if using Facebook login)
# Create at https://developers.facebook.com → My Apps
REACT_APP_FACEBOOK_APP_ID=
