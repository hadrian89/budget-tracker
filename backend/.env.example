# ──────────────────────────────────────────────────────────────
# Walleto Backend — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ──────────────────────────────────────────────────────────────

# MongoDB connection string
# Get this from MongoDB Atlas → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/budget_tracker?retryWrites=true&w=majority

# JWT signing secret
# Use a long, random string (32+ characters). Change in production.
JWT_SECRET=replace_with_a_strong_random_secret_string

# Server port (optional — defaults to 5001)
PORT=5001

# Additional CORS origins (optional — comma-separated, no spaces)
# The backend always allows localhost:3000. Add your production web domain here.
# ALLOWED_ORIGINS=https://yourapp.vercel.app,https://custom-domain.com
